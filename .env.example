# VIT Sports Intelligence Network v4 environment template
# Copy to .env for local development. Do not commit real secrets.

# Application
APP_VERSION=4.0.0
ENVIRONMENT=development
PORT=5000
BACKEND_PORT=8000
FRONTEND_PORT=5000
CORS_ALLOWED_ORIGINS=*
REPLIT_DEPLOYMENT=
REPL_SLUG=localhost

# Database
VIT_DATABASE_URL=sqlite+aiosqlite:///./vit.db
DATABASE_URL=
# PostgreSQL example:
# VIT_DATABASE_URL=postgresql+asyncpg://user:password@host:5432/vit_db

# Security and auth
SECRET_KEY=change-this-to-a-long-random-secret
JWT_SECRET_KEY=change-this-to-a-long-random-jwt-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
AUTH_ENABLED=false
API_KEY=

# Feature flags
USE_REAL_ML_MODELS=false
ML_MODEL_CACHE_ENABLED=true
BLOCKCHAIN_ENABLED=false

# Initial admin seed
ADMIN_EMAIL=admin@vit.network
ADMIN_USERNAME=vit_admin
ADMIN_PASSWORD=

# Background task supervision
BACKGROUND_TASK_CHECK_INTERVAL_SECONDS=30
BACKGROUND_TASK_MAX_RESTARTS=5

# Prediction and bankroll controls
MAX_STAKE=0.05
MIN_EDGE_THRESHOLD=0.02
LSTM_MAX_TRAINING_SEQS=2000

# Training defaults
DEFAULT_TRAINING_LEAGUES=premier_league,la_liga,serie_a,bundesliga,ligue_1
DEFAULT_LEAGUE=premier_league
DEFAULT_TRAINING_FROM=2023-01-01
DEFAULT_TRAINING_TO=2025-12-31
DEFAULT_VALIDATION_SPLIT=0.20
DEFAULT_EARLY_STOPPING=true
DEFAULT_MAX_EPOCHS=100
DEFAULT_LEARNING_RATE=0.001

# Data providers
FOOTBALL_DATA_API_KEY=
RAPIDAPI_KEY=
THE_ODDS_API_KEY=
ODDS_API_KEY=
ENABLE_SCRAPING=false
ENABLE_ODDS=true

# AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
BZZOIRO_API_KEY=
SPORTBOT_API_KEY=

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Payments and wallet
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
USDT_MIN_CONFIRMATIONS=3

# Blockchain/oracle
ORACLE_API_KEY=

# Optional worker/cache
REDIS_URL=

# Frontend
VITE_API_URL=
